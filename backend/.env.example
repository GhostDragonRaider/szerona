PORT=3000
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:3000
# Opcionális: ha megadod, a backend PostgreSQL-t használ.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/serona
DATABASE_SSL=false
# Ha nincs PostgreSQL, a backend automatikusan egy helyi SQLite adatbázisfájlra esik vissza.
SQLITE_PATH=./data/serona.sqlite
INVOICE_DIR=./data/invoices
# Vercelen productionben erősen ajánlott megadni a DATABASE_URL és JWT_SECRET
# értékeket. Ha ezek hiányoznak, a backend fallback módban ideiglenes /tmp
# SQLite-ot és deploy-szintű JWT titkot használ.
JWT_SECRET=csereld_le_egy_hosszu_veletlen_titokra
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=30
PASSWORD_RESET_MINUTES=60
EMAIL_VERIFICATION_MINUTES=1440
CART_RESERVATION_MINUTES=30
BRUTE_FORCE_WINDOW_MINUTES=15
BRUTE_FORCE_LOCK_MINUTES=30
BRUTE_FORCE_MAX_ATTEMPTS=5
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BCRYPT_ROUNDS=12
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
MAILERSEND_API_KEY=
MAILERSEND_API_BASE_URL=https://api.mailersend.com/v1
# Ha a sajat domain meg nincs verifikalva a Resendben, fejlesztoi kiprobalashoz maradhat az onboarding cim.
EMAIL_FROM_ADDRESS="Serona <onboarding@resend.dev>"
EMAIL_REPLY_TO=
ORDER_AUTOMATION_SECRET=
TRANSFER_BANK_ACCOUNT_HOLDER=Serona
TRANSFER_BANK_ACCOUNT_NUMBER=
TRANSFER_BANK_NAME=
TRANSFER_PAYMENT_DUE_DAYS=3
LOW_STOCK_THRESHOLD=5
GLS_API_BASE_URL=
GLS_CLIENT_NUMBER=
GLS_USERNAME=
GLS_PASSWORD=
# Fizetés: Barion hosted checkout + (opcionális) Számlázz.hu számla sikeres kártyás fizetés után.
# A POSKey / agentkulcs csak backend .env-ben legyen, soha ne kerüljön gitbe vagy a frontend buildbe.
PAYMENT_PROVIDER=barion
# Tokenizált (Stripe stb.) klienshez kell; tiszta Barion redirect módnál nem.
PAYMENT_PUBLIC_KEY=
# Teszt POS: állítsd true-ra, vagy add meg kézzel a teszt API-t (lásd lent).
BARION_SANDBOX=true
# Üresen: BARION_SANDBOX=true esetén https://api.test.barion.com/v2, egyébként éles Barion API.
BARION_API_BASE_URL=
BARION_POS_KEY=
# Kötelező a Barion Start híváshoz: a POS-hoz tartozó Barion wallet e-mail (a Shopban regisztrált).
BARION_PAYEE=
BARION_LOCALE=hu-HU
BARION_CURRENCY=HUF
BARION_FUNDING_SOURCES=All
# Éles és teszt számla-agent ugyanazon a HTTPS endpointon; a teszt agentkulcs a Számlázz tesztfiókból jön.
SZAMLAZZ_HU_API_BASE_URL=https://www.szamlazz.hu/szamla/
SZAMLAZZ_HU_AGENT_KEY=
SZAMLAZZ_HU_PREFIX=
SZAMLAZZ_HU_E_INVOICE=false
SZAMLAZZ_HU_DOWNLOAD_PDF=false
SZAMLAZZ_HU_VAT_RATE=27
