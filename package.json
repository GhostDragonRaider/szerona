{
  "name": "szerona",
  "version": "1.0.0",
  "description": "Serona webshop – React + TypeScript + Emotion frontend",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js -k -n frontend,backend -c blue,green \"npm:dev:frontend\" \"npm:dev:backend:watch\"",
    "dev:frontend": "node node_modules/vite/bin/vite.js",
    "dev:backend": "node backend/index.js",
    "dev:backend:watch": "node --watch backend/index.js",
    "build": "node node_modules/typescript/lib/tsc.js -b && node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "typecheck": "node node_modules/typescript/lib/tsc.js -b --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GhostDragonRaider/szerona.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/GhostDragonRaider/szerona/issues"
  },
  "homepage": "https://github.com/GhostDragonRaider/szerona#readme",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  }
}
