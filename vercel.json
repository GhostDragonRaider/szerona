{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth?path=:path*"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "/api/admin?path=:path*"
    },
    {
      "source": "/api/account/:path*",
      "destination": "/api/account?path=:path*"
    },
    {
      "source": "/api/commerce/:path*",
      "destination": "/api/commerce?path=:path*"
    },
    {
      "source": "/api/products/:path*",
      "destination": "/api/products?path=:path*"
    },
    {
      "source": "/api/cart/:path*",
      "destination": "/api/cart?path=:path*"
    },
    {
      "source": "/api/orders/:path*",
      "destination": "/api/orders?path=:path*"
    },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
